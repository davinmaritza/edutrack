# Database (PostgreSQL)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/postgres?schema=public"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:PORT/postgres?schema=public"

# Next Auth
NEXTAUTH_URL="http://localhost:3000"
AUTH_SECRET="your-secret-here" # Generate: openssl rand -base64 32
AUTH_TRUST_HOST=true

# Google OAuth
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Cloudflare Turnstile CAPTCHA
TURNSTILE_SECRET_KEY=""  # Get from Cloudflare Dashboard

# Vercel Analytics (Optional)
VERCEL_ANALYTICS_ID=""
